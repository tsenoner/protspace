{
  "name": "@protspace/utils",
  "version": "0.1.0",
  "description": "Utility functions for ProtSpace components",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:ci": "vitest --run",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "d3": "^7.9.0",
    "html2canvas-pro": "^1.5.11",
    "hyparquet-writer": "^0.7.0",
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
